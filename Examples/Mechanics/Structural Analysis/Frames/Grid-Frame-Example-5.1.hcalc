# 10 kip concentrated load at Node 1 (downward)
arrow3d 0 0 5 0 0 0.5
text3d 1 0 5.5 10 k
# 200 k-in torsional moment at L/2 on Element 1
color #9900cc
carc3d 10 0 0 0.8 0.2 4.0
