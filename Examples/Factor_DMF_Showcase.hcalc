## 14. Go — @{go}

@{go}
package main
import (
    "fmt"
    "math"
)
func main() {
    xi := []float64{0.125, 0.2, 0.25, 0.5, 0.707, 1.0, 2.0}
    fmt.Println("  DMF — Go")
    fmt.Println("  xi       | D(r=1)")
    fmt.Println("  ---------|-------")
    for _, x := range xi {
        d := 1.0 / (2.0 * x)
        _ = math.Sqrt(d)
        fmt.Printf("  %-9.3f| %.4f\n", x, d)
    }
}
@{end go}

