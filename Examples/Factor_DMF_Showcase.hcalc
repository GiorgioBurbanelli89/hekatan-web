## 12. Bash — @{bash}

@{bash}
echo "  DMF — Bash"
echo "  ========================="
echo "  xi       | D(r=1)"
echo "  ---------|-------"
for xi in 0.125 0.200 0.250 0.500 0.707 1.000 2.000; do
    D=$(awk "BEGIN{printf \"%.4f\", 1/(2*$xi)}")
    printf "  %-9s| %s\n" "$xi" "$D"
done
echo "  ========================="
@{end bash}

