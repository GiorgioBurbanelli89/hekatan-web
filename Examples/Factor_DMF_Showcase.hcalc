## 22. Octave — @{octave}

@{octave}
graphics_toolkit('gnuplot');
set(0, 'defaultfigurevisible', 'off');
xi = [0.125, 0.2, 0.25, 0.5, 0.707, 1.0, 2.0];
cols = {'#E53935','#7CB342','#1E88E5','#FFB300','#C2185B','#00C853','#7B1FA2'};
r = linspace(0.01, 3, 300);

hf = figure();
set(hf, '__graphics_toolkit__', 'gnuplot');
hold on;
for k = 1:length(xi)
  D = 1 ./ sqrt((1 - r.^2).^2 + (2*xi(k)*r).^2);
  D = min(D, 4.5);
  if k < 5
    plot(r, D, '-', 'Color', cols{k}, 'LineWidth', 2);
  else
    plot(r, D, '--', 'Color', cols{k}, 'LineWidth', 1.5);
  end
end
hold off;
axis([0 3 0 4.5]);
xlabel('r = w/wn'); ylabel('D(r,xi)');
title('Octave — Factor de Magnificacion Dinamica');
% Build legend labels without anonymous functions (no @() — parser converts to <div>)
leg = cell(1, length(xi));
for k = 1:length(xi)
  leg{k} = sprintf('xi=%.3f', xi(k));
end
legend(leg, 'Location','northeast');
grid on;

% Save as PNG (better quality than gnuplot SVG), encode base64, emit @@image DSL
tmpf = [tempname() '.png'];
print(hf, tmpf, '-dpng', '-r150');
fid = fopen(tmpf, 'rb');
data = fread(fid, Inf, 'uint8');
fclose(fid);
b64 = base64_encode(uint8(data'));
fprintf('@@image data:image/png;base64,%s|DMF Octave|100%%|Octave - Factor de Magnificacion Dinamica\n', b64);
delete(tmpf);
@{end octave}

