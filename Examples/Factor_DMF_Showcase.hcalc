## 9. C# — @{csharp}

@{csharp}
using System;
class Program {
    static double Sx(double v, int ml, int pw) { return ml + v / 3.0 * pw; }
    static double Sy(double v, int mt, int ph) { return mt + ph - v / 4.5 * ph; }
    static double DMF(double r, double xi) {
        double d = Math.Pow(1 - r * r, 2) + Math.Pow(2 * xi * r, 2);
        return d > 1e-12 ? Math.Min(1.0 / Math.Sqrt(d), 4.5) : 4.5;
    }
    static void Main() {
        int W = 650, H = 400, ml = 55, mr = 25, mt = 30, mb = 45;
        int pw = W - ml - mr, ph = H - mt - mb;
        double[] xi = {0.125, 0.2, 0.25, 0.5, 0.707, 1.0, 2.0};
        string[] cols = {"#E53935","#7CB342","#1E88E5","#FFB300","#C2185B","#00C853","#7B1FA2"};
        Console.Write($"<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"{W}\" height=\"{H}\" style=\"font-family:sans-serif;background:white\">\n");
        Console.Write($"<rect x=\"{ml}\" y=\"{mt}\" width=\"{pw}\" height=\"{ph}\" fill=\"none\" stroke=\"#999\"/>\n");
        Console.Write($"<text x=\"{W/2}\" y=\"18\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"bold\">C# SVG</text>\n");
        for (int i = 0; i < 4; i++) {
            Console.Write($"<line x1=\"{Sx(i,ml,pw):F1}\" y1=\"{mt}\" x2=\"{Sx(i,ml,pw):F1}\" y2=\"{mt+ph}\" stroke=\"#e8e8e8\"/>\n");
            Console.Write($"<text x=\"{Sx(i,ml,pw):F1}\" y=\"{mt+ph+16}\" text-anchor=\"middle\" font-size=\"11\">{i}</text>\n");
        }
        for (int j = 0; j < 5; j++) {
            Console.Write($"<line x1=\"{ml}\" y1=\"{Sy(j,mt,ph):F1}\" x2=\"{ml+pw}\" y2=\"{Sy(j,mt,ph):F1}\" stroke=\"#e8e8e8\"/>\n");
            Console.Write($"<text x=\"{ml-8}\" y=\"{Sy(j,mt,ph)+4:F1}\" text-anchor=\"end\" font-size=\"11\">{j}</text>\n");
        }
        for (int k = 0; k < 7; k++) {
            Console.Write("<polyline points=\"");
            for (int i = 0; i < 300; i++) {
                double r = 0.01 + i * 2.99 / 299.0;
                Console.Write($"{Sx(r,ml,pw):F1},{Sy(DMF(r,xi[k]),mt,ph):F1} ");
            }
            string dash = k > 3 ? " stroke-dasharray=\"8,4\"" : "";
            string lw = k < 4 ? "2" : "1.5";
            Console.Write($"\" fill=\"none\" stroke=\"{cols[k]}\" stroke-width=\"{lw}\"{dash}/>\n");
        }
        int lx = ml + pw - 110;
        Console.Write($"<rect x=\"{lx-5}\" y=\"{mt+6}\" width=\"115\" height=\"{7*16+8}\" rx=\"3\" fill=\"white\" fill-opacity=\"0.9\" stroke=\"#ddd\"/>\n");
        for (int k = 0; k < 7; k++) {
            int yy = mt + 20 + k * 16;
            string dash = k > 3 ? " stroke-dasharray=\"6,3\"" : "";
            Console.Write($"<line x1=\"{lx}\" y1=\"{yy}\" x2=\"{lx+22}\" y2=\"{yy}\" stroke=\"{cols[k]}\" stroke-width=\"2\"{dash}/>\n");
            Console.Write($"<text x=\"{lx+27}\" y=\"{yy+4}\" font-size=\"10\">{xi[k]}</text>\n");
        }
        Console.Write("</svg>\n");
    }
}
@{end csharp}

