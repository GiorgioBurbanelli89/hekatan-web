## 8. JavaScript — @{js}

@{js}
const W = 650, H = 400;
const ml = 55, mr = 25, mt = 30, mb = 45;
const pw = W - ml - mr, ph = H - mt - mb;
const xmin = 0, xmax = 3, ymin = 0, ymax = 4.5;
function sx(v) { return ml + (v - xmin) / (xmax - xmin) * pw; }
function sy(v) { return mt + ph - (v - ymin) / (ymax - ymin) * ph; }
const xi = [0.125, 0.2, 0.25, 0.5, 0.707, 1.0, 2.0];
const cols = ['#E53935','#7CB342','#1E88E5','#FFB300','#C2185B','#00C853','#7B1FA2'];
function D(r, x) {
    const d = Math.pow(1 - r * r, 2) + Math.pow(2 * x * r, 2);
    return d > 1e-12 ? Math.min(1 / Math.sqrt(d), 4.5) : 4.5;
}
let o = `<svg xmlns="http://www.w3.org/2000/svg" width="${W}" height="${H}" style="font-family:sans-serif;background:white">\n`;
for (let i = 0; i < 4; i++) {
    o += `<line x1="${sx(i).toFixed(1)}" y1="${mt}" x2="${sx(i).toFixed(1)}" y2="${mt+ph}" stroke="#e8e8e8"/>\n`;
    o += `<text x="${sx(i).toFixed(1)}" y="${mt+ph+16}" text-anchor="middle" font-size="11">${i}</text>\n`;
}
for (let j = 0; j < 5; j++) {
    o += `<line x1="${ml}" y1="${sy(j).toFixed(1)}" x2="${ml+pw}" y2="${sy(j).toFixed(1)}" stroke="#e8e8e8"/>\n`;
    o += `<text x="${ml-8}" y="${(sy(j)+4).toFixed(1)}" text-anchor="end" font-size="11">${j}</text>\n`;
}
o += `<rect x="${ml}" y="${mt}" width="${pw}" height="${ph}" fill="none" stroke="#999"/>\n`;
o += `<text x="${W/2}" y="18" text-anchor="middle" font-size="13" font-weight="bold">JavaScript SVG</text>\n`;
for (let k = 0; k < 7; k++) {
    let pts = '';
    for (let i = 0; i < 300; i++) {
        const r = 0.01 + i * 2.99 / 299;
        pts += `${sx(r).toFixed(1)},${sy(D(r, xi[k])).toFixed(1)} `;
    }
    const dash = k > 3 ? ' stroke-dasharray="8,4"' : '';
    const lw = k < 4 ? '2' : '1.5';
    o += `<polyline points="${pts}" fill="none" stroke="${cols[k]}" stroke-width="${lw}"${dash}/>\n`;
}
const lx = ml + pw - 110;
o += `<rect x="${lx-5}" y="${mt+6}" width="115" height="${7*16+8}" rx="3" fill="white" fill-opacity="0.9" stroke="#ddd"/>\n`;
for (let k = 0; k < 7; k++) {
    const yy = mt + 20 + k * 16;
    const dash = k > 3 ? ' stroke-dasharray="6,3"' : '';
    o += `<line x1="${lx}" y1="${yy}" x2="${lx+22}" y2="${yy}" stroke="${cols[k]}" stroke-width="2"${dash}/>\n`;
    o += `<text x="${lx+27}" y="${yy+4}" font-size="10">${xi[k]}</text>\n`;
}
o += '</svg>';
console.log(o);
@{end js}

