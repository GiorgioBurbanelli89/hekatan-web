## 11. C++ — @{cpp}

@{cpp}
#include <cmath>
#include <cstdio>
int main() {
    const int W=650,H=400,ml=55,mr=25,mt=30,mb=45;
    const int pw=W-ml-mr, ph=H-mt-mb;
    double xi[]={0.125,0.2,0.25,0.5,0.707,1.0,2.0};
    const char* cl[]={"#E53935","#7CB342","#1E88E5","#FFB300","#C2185B","#00C853","#7B1FA2"};
    auto sx=[&](double v){return ml+v/3.0*pw;};
    auto sy=[&](double v){return mt+ph-v/4.5*ph;};
    printf("<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"%d\" height=\"%d\" style=\"background:#fff;font-family:sans-serif\">\n",W,H);
    printf("<rect x=\"%d\" y=\"%d\" width=\"%d\" height=\"%d\" fill=\"none\" stroke=\"#999\"/>\n",ml,mt,pw,ph);
    printf("<text x=\"%d\" y=\"18\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"bold\">C++ SVG</text>\n",W/2);
    for(int i=0;i<4;i++){
        printf("<line x1=\"%.0f\" y1=\"%d\" x2=\"%.0f\" y2=\"%d\" stroke=\"#e8e8e8\"/>\n",sx(i),mt,sx(i),mt+ph);
        printf("<text x=\"%.0f\" y=\"%d\" text-anchor=\"middle\" font-size=\"11\">%d</text>\n",sx(i),mt+ph+16,i);
    }
    for(int j=0;j<5;j++){
        printf("<line x1=\"%d\" y1=\"%.0f\" x2=\"%d\" y2=\"%.0f\" stroke=\"#e8e8e8\"/>\n",ml,sy(j),ml+pw,sy(j));
        printf("<text x=\"%d\" y=\"%.0f\" text-anchor=\"end\" font-size=\"11\">%d</text>\n",ml-8,sy(j)+4,j);
    }
    for(int k=0;k<7;k++){
        printf("<polyline points=\"");
        for(int i=0;i<300;i++){
            double r=0.01+i*2.99/299.0;
            double d=pow(1-r*r,2)+pow(2*xi[k]*r,2);
            double D=d>1e-12?fmin(1.0/sqrt(d),4.5):4.5;
            printf("%.1f,%.1f ",sx(r),sy(D));
        }
        const char* da=k>3?" stroke-dasharray=\"8,4\"":"";
        const char* lw=k<4?"2":"1.5";
        printf("\" fill=\"none\" stroke=\"%s\" stroke-width=\"%s\"%s/>\n",cl[k],lw,da);
    }
    int lx=ml+pw-110;
    printf("<rect x=\"%d\" y=\"%d\" width=\"115\" height=\"%d\" rx=\"3\" fill=\"white\" fill-opacity=\"0.9\" stroke=\"#ddd\"/>\n",lx-5,mt+6,7*16+8);
    for(int k=0;k<7;k++){
        int yy=mt+20+k*16;
        const char* da=k>3?" stroke-dasharray=\"6,3\"":"";
        printf("<line x1=\"%d\" y1=\"%d\" x2=\"%d\" y2=\"%d\" stroke=\"%s\" stroke-width=\"2\"%s/>\n",lx,yy,lx+22,yy,cl[k],da);
        printf("<text x=\"%d\" y=\"%d\" font-size=\"10\">%.3f</text>\n",lx+27,yy+4,xi[k]);
    }
    printf("</svg>\n");
    return 0;
}
@{end cpp}

