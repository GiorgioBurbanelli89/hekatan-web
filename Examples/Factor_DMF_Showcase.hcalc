    xi = (/0.125d0, 0.2d0, 0.25d0, 0.5d0, 0.707d0, 1.0d0, 2.0d0/)
    write(*,'(A)') '  DMF — Fortran'
    write(*,'(A)') '  xi       | D(r=1)'
    write(*,'(A)') '  ---------|-------'
    do i = 1, 7
        d = 1.0d0 / (2.0d0 * xi(i))
        write(*,'(A,F7.3,A,F7.4)') '  ', xi(i), '  | ', d
    end do
end program dmf
@{end fortran}

