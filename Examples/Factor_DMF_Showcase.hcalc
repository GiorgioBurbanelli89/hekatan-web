## 13. Rust — @{rust}

@{rust}
fn main() {
    let xi: [f64; 7] = [0.125, 0.2, 0.25, 0.5, 0.707, 1.0, 2.0];
    println!("  DMF — Rust");
    println!("  xi       | D(r=1)");
    println!("  ---------|-------");
    for &x in &xi {
        let d: f64 = 1.0 / (2.0 * x);
        println!("  {:<9.3}| {:.4}", x, d);
    }
}
@{end rust}

