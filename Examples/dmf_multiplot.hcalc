"Factor de Magnificación Dinámica — Múltiples Métodos
'<h3 style="color:#2563eb">D = 1 / √[(1 − r²)² + (2ξr)²]</h3>
'<hr>

"<h2>① @{calcpad} — Calcpad Nativo con $Plot{}</h2>
@{calcpad}
#hide
PlotWidth = 600
PlotHeight = 400
PlotSVG = 1
#show
D_1(r) = 1/sqr((1 - r^2)^2 + (2*0.125*r)^2)
D_2(r) = 1/sqr((1 - r^2)^2 + (2*0.2*r)^2)
D_3(r) = 1/sqr((1 - r^2)^2 + (2*0.25*r)^2)
D_4(r) = 1/sqr((1 - r^2)^2 + (2*0.4*r)^2)
D_5(r) = 1/sqr((1 - r^2)^2 + (2*0.7*r)^2)
D_6(r) = 1/sqr((1 - r^2)^2 + (2*1.0*r)^2)
D_7(r) = 1/sqr((1 - r^2)^2 + (2*2.0*r)^2)
$Plot{D_1(r) & D_2(r) & D_3(r) & D_4(r) & D_5(r) & D_6(r) & D_7(r) @ r = 0.01 : 3}
@{end calcpad}

