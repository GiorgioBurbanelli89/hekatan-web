<Window x:Class="Hekatan.AiAgent.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Hekatan AI Agent - CAD Generador" Height="800" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <Grid Margin="6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350" MinWidth="280"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="320" MinWidth="250"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ PANEL IZQUIERDO: Chat ═══ -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Titulo -->
            <TextBlock Grid.Row="0" Text="Hekatan AI Agent"
                       FontSize="18" FontWeight="Bold"
                       Foreground="#4FC3F7" Margin="0,0,0,6"/>

            <!-- API Key + Modelo -->
            <Grid Grid.Row="1" Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="API Key:" Foreground="#aaa" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="11"/>
                <PasswordBox x:Name="txtApiKey" Grid.Column="1"
                             Background="#2D2D2D" Foreground="White"
                             BorderBrush="#444" Padding="4" FontSize="11"/>
            </Grid>

            <!-- Modelo + Modo -->
            <Grid Grid.Row="2" Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="cboModelo" Margin="0,0,3,0"
                          Background="#2D2D2D" Foreground="Black" Padding="4" FontSize="10"
                          SelectedIndex="0">
                    <ComboBoxItem Content="llama-3.3-70b-versatile"/>
                    <ComboBoxItem Content="meta-llama/llama-4-scout-17b-16e-instruct" Tag="vision"/>
                    <ComboBoxItem Content="llama-3.1-8b-instant"/>
                    <ComboBoxItem Content="mixtral-8x7b-32768"/>
                    <ComboBoxItem Content="gemma2-9b-it"/>
                </ComboBox>
                <ComboBox x:Name="cboModo" Grid.Column="1" Margin="3,0,0,0"
                          Background="#2D2D2D" Foreground="Black"
                          Padding="4" FontSize="10" SelectedIndex="0">
                    <ComboBoxItem Content="CAD CLI (2D)"/>
                    <ComboBoxItem Content="SVG"/>
                    <ComboBoxItem Content="Three.js (3D)"/>
                    <ComboBoxItem Content="CSS"/>
                    <ComboBoxItem Content="Calculo"/>
                </ComboBox>
            </Grid>

            <!-- Imagen preview -->
            <Border Grid.Row="3" Background="#2D2D2D" CornerRadius="4" Padding="3" Margin="0,0,0,4"
                    MaxHeight="90" Visibility="{Binding ElementName=imgPreview, Path=Visibility}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Image x:Name="imgPreview" MaxHeight="70" MaxWidth="120"
                           Stretch="Uniform" Margin="2" Visibility="Collapsed"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="6,0">
                        <TextBlock x:Name="lblImagen" Text="" Foreground="#66bb6a" FontSize="10" TextWrapping="Wrap"/>
                        <TextBlock Text="Ctrl+V | Drag &amp; Drop" Foreground="#555" FontSize="9"/>
                    </StackPanel>
                    <Button x:Name="btnQuitarImagen" Grid.Column="2" Content="X"
                            Width="22" Height="22" Margin="2"
                            Background="#c62828" Foreground="White" FontWeight="Bold" FontSize="10"
                            Click="btnQuitarImagen_Click" Cursor="Hand" Visibility="Collapsed">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="11">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- Area de chat -->
            <Border Grid.Row="4" Background="#252526" CornerRadius="4" Padding="6" Margin="0,0,0,4">
                <ScrollViewer x:Name="scrollChat" VerticalScrollBarVisibility="Auto">
                    <TextBox x:Name="txtChat"
                             Background="Transparent" Foreground="#D4D4D4"
                             BorderThickness="0" IsReadOnly="True"
                             TextWrapping="Wrap" FontFamily="Cascadia Code, Consolas"
                             FontSize="11" AcceptsReturn="True"/>
                </ScrollViewer>
            </Border>

            <!-- Entrada -->
            <Grid Grid.Row="5" Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="btnCargarImagen" Content="Img" Width="35"
                        Background="#37474f" Foreground="White" FontSize="10"
                        Click="btnCargarImagen_Click" Cursor="Hand" Margin="0,0,4,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <TextBox x:Name="txtMensaje" Grid.Column="1"
                         Background="#2D2D2D" Foreground="White"
                         BorderBrush="#444" Padding="8" FontSize="12"
                         AcceptsReturn="True" TextWrapping="Wrap" MaxHeight="60"
                         KeyDown="txtMensaje_KeyDown"
                         VerticalContentAlignment="Center"/>
                <Button x:Name="btnEnviar" Grid.Column="2" Content="Generar"
                        Width="70" Margin="4,0,0,0"
                        Background="#4FC3F7" Foreground="Black"
                        FontWeight="Bold" FontSize="12"
                        Click="btnEnviar_Click" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- Status -->
            <TextBlock x:Name="lblStatus" Grid.Row="6" Foreground="#666" FontSize="9"
                       TextWrapping="Wrap"
                       Text="Listo. Describe lo que quieres dibujar o carga una imagen."/>
        </Grid>

        <!-- Separador 1 -->
        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#333"/>

        <!-- ═══ PANEL CENTRAL: Preview CAD (WebView2) ═══ -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Titulo + Controles preview -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="4,0,0,4">
                <TextBlock Text="CAD Preview" FontSize="14" FontWeight="Bold"
                           Foreground="#4ec9b0" VerticalAlignment="Center"/>
                <Button x:Name="btnReviewAI" Content="AI Review" Margin="12,0,0,0" Padding="8,3"
                        Background="#6a1b9a" Foreground="White" FontSize="10"
                        Click="btnReviewAI_Click" Cursor="Hand" ToolTip="El AI revisa el dibujo y sugiere correcciones">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="8,3">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="btnClearCAD" Content="Limpiar" Margin="6,0,0,0" Padding="8,3"
                        Background="#555" Foreground="White" FontSize="10"
                        Click="btnClearCAD_Click" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="8,3">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <CheckBox x:Name="chkAutoReview" Content="Auto-review" Foreground="#888"
                          FontSize="10" VerticalAlignment="Center" Margin="12,0,0,0"
                          IsChecked="False" ToolTip="Revisa automaticamente el dibujo despues de generar"/>
                <TextBlock x:Name="lblShapes" Text="" Foreground="#888" FontSize="10"
                           VerticalAlignment="Center" Margin="12,0,0,0"/>
            </StackPanel>

            <!-- WebView2 CAD Preview -->
            <Border Grid.Row="1" Background="#1a1a2e" CornerRadius="4" ClipToBounds="True">
                <wv2:WebView2 x:Name="webCad" DefaultBackgroundColor="#FF1A1A2E"/>
            </Border>

            <TextBlock x:Name="lblPreviewInfo" Grid.Row="2" Foreground="#555" FontSize="9" Margin="4,3,0,0"
                       Text="Preview CAD 2D - Los comandos se ejecutan aqui automaticamente"/>
        </Grid>

        <!-- Separador 2 -->
        <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch" Background="#333"/>

        <!-- ═══ PANEL DERECHO: Codigo ═══ -->
        <Grid Grid.Column="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Titulo + Botones -->
            <StackPanel Grid.Row="0" Margin="4,0,0,4">
                <TextBlock Text="Comandos CAD" FontSize="14" FontWeight="Bold"
                           Foreground="#81c784" Margin="0,0,0,4"/>
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="btnEjecutar" Content="Ejecutar" Padding="8,3"
                            Background="#2e7d32" Foreground="White" FontSize="10"
                            Click="btnEjecutar_Click" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="8,3">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="btnCopiar" Content="Copiar" Margin="4,0,0,0" Padding="8,3"
                            Background="#1565c0" Foreground="White" FontSize="10"
                            Click="btnCopiar_Click" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="8,3">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="btnGuardar" Content="Guardar" Margin="4,0,0,0" Padding="8,3"
                            Background="#555" Foreground="White" FontSize="10"
                            Click="btnGuardar_Click" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="8,3">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </StackPanel>

            <!-- Editor de comandos -->
            <Border Grid.Row="1" Background="#1a1a2e" CornerRadius="4" Padding="6" Margin="0,4,0,0">
                <TextBox x:Name="txtCodigo"
                         Background="Transparent" Foreground="#a5d6a7"
                         BorderThickness="0" AcceptsReturn="True" AcceptsTab="True"
                         TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         FontFamily="Cascadia Code, Consolas, Courier New"
                         FontSize="11"/>
            </Border>

            <!-- Info -->
            <TextBlock x:Name="lblInfo" Grid.Row="2" Foreground="#555" FontSize="9" Margin="4,3,0,0"
                       TextWrapping="Wrap"
                       Text="Edita los comandos y pulsa Ejecutar para ver el resultado"/>
        </Grid>
    </Grid>
</Window>
