<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================== -->
    <!-- HEKATAN CALC - DARK THEME (Egyptian Gold)     -->
    <!-- The Magic of Calculation                       -->
    <!-- ============================================== -->

    <!-- Primary Colors - Egyptian Gold -->
    <Color x:Key="PrimaryColor">#D4AF37</Color>
    <Color x:Key="PrimaryLightColor">#F4D03F</Color>
    <Color x:Key="PrimaryDarkColor">#B8960C</Color>

    <!-- Accent Colors - Turquoise/Cyan -->
    <Color x:Key="AccentColor">#00D4AA</Color>
    <Color x:Key="AccentLightColor">#00FFAA</Color>
    <Color x:Key="AccentDarkColor">#00C8A0</Color>

    <!-- Background Colors - Deep Dark -->
    <Color x:Key="BackgroundPrimaryColor">#0A0A0F</Color>
    <Color x:Key="BackgroundSecondaryColor">#0F0F18</Color>
    <Color x:Key="BackgroundCardColor">#12121A</Color>
    <Color x:Key="BackgroundElevatedColor">#1A1A25</Color>
    <Color x:Key="BackgroundHoverColor">#252530</Color>

    <!-- Text Colors -->
    <Color x:Key="TextPrimaryColor">#FFFFFF</Color>
    <Color x:Key="TextSecondaryColor">#A0A0B0</Color>
    <Color x:Key="TextMutedColor">#888888</Color>
    <Color x:Key="TextDisabledColor">#555555</Color>

    <!-- Border Colors -->
    <Color x:Key="BorderColor">#2A2A35</Color>
    <Color x:Key="BorderActiveColor">#D4AF37</Color>
    <Color x:Key="BorderHoverColor">#00D4AA</Color>

    <!-- Status Colors -->
    <Color x:Key="SuccessColor">#00D4AA</Color>
    <Color x:Key="WarningColor">#F4D03F</Color>
    <Color x:Key="ErrorColor">#FF6B6B</Color>
    <Color x:Key="InfoColor">#4ECDC4</Color>

    <!-- ============================================== -->
    <!-- SOLID COLOR BRUSHES                            -->
    <!-- ============================================== -->

    <!-- Primary Brushes -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryLightColor}"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDarkColor}"/>

    <!-- Accent Brushes -->
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentLightBrush" Color="{StaticResource AccentLightColor}"/>
    <SolidColorBrush x:Key="AccentDarkBrush" Color="{StaticResource AccentDarkColor}"/>

    <!-- Background Brushes -->
    <SolidColorBrush x:Key="BackgroundPrimaryBrush" Color="{StaticResource BackgroundPrimaryColor}"/>
    <SolidColorBrush x:Key="BackgroundSecondaryBrush" Color="{StaticResource BackgroundSecondaryColor}"/>
    <SolidColorBrush x:Key="BackgroundCardBrush" Color="{StaticResource BackgroundCardColor}"/>
    <SolidColorBrush x:Key="BackgroundElevatedBrush" Color="{StaticResource BackgroundElevatedColor}"/>
    <SolidColorBrush x:Key="BackgroundHoverBrush" Color="{StaticResource BackgroundHoverColor}"/>

    <!-- Text Brushes -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource TextDisabledColor}"/>

    <!-- Border Brushes -->
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="BorderActiveBrush" Color="{StaticResource BorderActiveColor}"/>
    <SolidColorBrush x:Key="BorderHoverBrush" Color="{StaticResource BorderHoverColor}"/>

    <!-- Status Brushes -->
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>

    <!-- ============================================== -->
    <!-- GRADIENT BRUSHES                               -->
    <!-- ============================================== -->

    <!-- Gold Gradient (Primary) -->
    <LinearGradientBrush x:Key="PrimaryGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#D4AF37" Offset="0"/>
        <GradientStop Color="#F4D03F" Offset="0.5"/>
        <GradientStop Color="#D4AF37" Offset="1"/>
    </LinearGradientBrush>

    <!-- Toolbar Gradient -->
    <LinearGradientBrush x:Key="ToolbarGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#1A1A25" Offset="0"/>
        <GradientStop Color="#12121A" Offset="1"/>
    </LinearGradientBrush>

    <!-- Card Gradient -->
    <LinearGradientBrush x:Key="CardGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#12121A" Offset="0"/>
        <GradientStop Color="#0A0A0F" Offset="1"/>
    </LinearGradientBrush>

    <!-- Button Hover Gradient -->
    <LinearGradientBrush x:Key="ButtonHoverGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#252530" Offset="0"/>
        <GradientStop Color="#1A1A25" Offset="1"/>
    </LinearGradientBrush>

    <!-- Accent Gradient -->
    <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#00D4AA" Offset="0"/>
        <GradientStop Color="#00FFAA" Offset="0.5"/>
        <GradientStop Color="#00D4AA" Offset="1"/>
    </LinearGradientBrush>

    <!-- ============================================== -->
    <!-- WINDOW & CONTROL BRUSHES (for theming)        -->
    <!-- ============================================== -->

    <!-- Window -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource BackgroundPrimaryColor}"/>
    <SolidColorBrush x:Key="WindowForegroundBrush" Color="{StaticResource TextPrimaryColor}"/>

    <!-- Menu -->
    <SolidColorBrush x:Key="MenuBackgroundBrush" Color="{StaticResource BackgroundCardColor}"/>
    <SolidColorBrush x:Key="MenuForegroundBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="MenuHoverBackgroundBrush" Color="{StaticResource BackgroundHoverColor}"/>
    <SolidColorBrush x:Key="MenuBorderBrush" Color="{StaticResource BorderColor}"/>

    <!-- Button -->
    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="{StaticResource BackgroundCardColor}"/>
    <SolidColorBrush x:Key="ButtonForegroundBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="ButtonHoverBackgroundBrush" Color="{StaticResource BackgroundHoverColor}"/>
    <SolidColorBrush x:Key="ButtonPressedBackgroundBrush" Color="{StaticResource BackgroundElevatedColor}"/>
    <SolidColorBrush x:Key="ButtonBorderBrush" Color="{StaticResource BorderColor}"/>

    <!-- TextBox / Editor -->
    <SolidColorBrush x:Key="EditorBackgroundBrush" Color="{StaticResource BackgroundSecondaryColor}"/>
    <SolidColorBrush x:Key="EditorForegroundBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="EditorBorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="EditorSelectionBrush" Color="#40D4AF37"/>

    <!-- TabControl -->
    <SolidColorBrush x:Key="TabBackgroundBrush" Color="{StaticResource BackgroundCardColor}"/>
    <SolidColorBrush x:Key="TabSelectedBackgroundBrush" Color="{StaticResource BackgroundElevatedColor}"/>
    <SolidColorBrush x:Key="TabForegroundBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TabSelectedForegroundBrush" Color="{StaticResource PrimaryColor}"/>

    <!-- ScrollBar -->
    <SolidColorBrush x:Key="ScrollBarBackgroundBrush" Color="{StaticResource BackgroundSecondaryColor}"/>
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="{StaticResource PrimaryDarkColor}"/>

    <!-- Toggle/Radio Button -->
    <SolidColorBrush x:Key="ToggleBackgroundBrush" Color="{StaticResource BackgroundCardColor}"/>
    <SolidColorBrush x:Key="ToggleCheckedBackgroundBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="ToggleForegroundBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="ToggleCheckedForegroundBrush" Color="{StaticResource BackgroundPrimaryColor}"/>

    <!-- Greek Letter Panel -->
    <SolidColorBrush x:Key="GreekLetterHoverBrush" Color="#30D4AF37"/>

    <!-- Syntax Highlighting Colors -->
    <SolidColorBrush x:Key="SyntaxKeywordBrush" Color="#D4AF37"/>
    <SolidColorBrush x:Key="SyntaxFunctionBrush" Color="#00D4AA"/>
    <SolidColorBrush x:Key="SyntaxNumberBrush" Color="#F4D03F"/>
    <SolidColorBrush x:Key="SyntaxStringBrush" Color="#98C379"/>
    <SolidColorBrush x:Key="SyntaxCommentBrush" Color="#5C6370"/>
    <SolidColorBrush x:Key="SyntaxOperatorBrush" Color="#C678DD"/>
    <SolidColorBrush x:Key="SyntaxErrorBrush" Color="#FF6B6B"/>

    <!-- Output Panel -->
    <SolidColorBrush x:Key="OutputBackgroundBrush" Color="#0A0A0F"/>
    <SolidColorBrush x:Key="OutputBorderBrush" Color="#2A2A35"/>

    <!-- Splitter -->
    <SolidColorBrush x:Key="SplitterBackgroundBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="SplitterHoverBrush" Color="{StaticResource PrimaryColor}"/>

</ResourceDictionary>
