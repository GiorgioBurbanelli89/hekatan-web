<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================== -->
    <!-- HEKATAN CALC - CLASSIC THEME                   -->
    <!-- Original Hekatan style (Light/Blue)            -->
    <!-- ============================================== -->

    <!-- Primary Colors - Blue (Original Hekatan) -->
    <Color x:Key="PrimaryColor">#3C7FB1</Color>
    <Color x:Key="PrimaryLightColor">#BEE6FD</Color>
    <Color x:Key="PrimaryDarkColor">#2A5A80</Color>

    <!-- Accent Colors - Purple/Magenta -->
    <Color x:Key="AccentColor">#7B68EE</Color>
    <Color x:Key="AccentLightColor">#9F8FFF</Color>
    <Color x:Key="AccentDarkColor">#5A4ACB</Color>

    <!-- Background Colors - Light Classic -->
    <Color x:Key="BackgroundPrimaryColor">#FFFFFF</Color>
    <Color x:Key="BackgroundSecondaryColor">#F5F5F5</Color>
    <Color x:Key="BackgroundCardColor">#FFFFFF</Color>
    <Color x:Key="BackgroundElevatedColor">#EEEEEE</Color>
    <Color x:Key="BackgroundHoverColor">#BEE6FD</Color>

    <!-- Text Colors -->
    <Color x:Key="TextPrimaryColor">#000000</Color>
    <Color x:Key="TextSecondaryColor">#444444</Color>
    <Color x:Key="TextMutedColor">#666666</Color>
    <Color x:Key="TextDisabledColor">#AAAAAA</Color>

    <!-- Border Colors -->
    <Color x:Key="BorderColor">#DDDDDD</Color>
    <Color x:Key="BorderActiveColor">#3C7FB1</Color>
    <Color x:Key="BorderHoverColor">#A03C7FB1</Color>

    <!-- Status Colors -->
    <Color x:Key="SuccessColor">#228B22</Color>
    <Color x:Key="WarningColor">#DAA520</Color>
    <Color x:Key="ErrorColor">#DC143C</Color>
    <Color x:Key="InfoColor">#4169E1</Color>

    <!-- ============================================== -->
    <!-- SOLID COLOR BRUSHES                            -->
    <!-- ============================================== -->

    <!-- Primary Brushes -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryLightColor}"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDarkColor}"/>

    <!-- Accent Brushes -->
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentLightBrush" Color="{StaticResource AccentLightColor}"/>
    <SolidColorBrush x:Key="AccentDarkBrush" Color="{StaticResource AccentDarkColor}"/>

    <!-- Background Brushes -->
    <SolidColorBrush x:Key="BackgroundPrimaryBrush" Color="{StaticResource BackgroundPrimaryColor}"/>
    <SolidColorBrush x:Key="BackgroundSecondaryBrush" Color="{StaticResource BackgroundSecondaryColor}"/>
    <SolidColorBrush x:Key="BackgroundCardBrush" Color="{StaticResource BackgroundCardColor}"/>
    <SolidColorBrush x:Key="BackgroundElevatedBrush" Color="{StaticResource BackgroundElevatedColor}"/>
    <SolidColorBrush x:Key="BackgroundHoverBrush" Color="{StaticResource BackgroundHoverColor}"/>

    <!-- Text Brushes -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource TextDisabledColor}"/>

    <!-- Border Brushes -->
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="BorderActiveBrush" Color="{StaticResource BorderActiveColor}"/>
    <SolidColorBrush x:Key="BorderHoverBrush" Color="{StaticResource BorderHoverColor}"/>

    <!-- Status Brushes -->
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>

    <!-- ============================================== -->
    <!-- GRADIENT BRUSHES                               -->
    <!-- ============================================== -->

    <!-- Blue Gradient (Primary) -->
    <LinearGradientBrush x:Key="PrimaryGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#3C7FB1" Offset="0"/>
        <GradientStop Color="#5AA3D4" Offset="0.5"/>
        <GradientStop Color="#3C7FB1" Offset="1"/>
    </LinearGradientBrush>

    <!-- Toolbar Gradient (Original) -->
    <LinearGradientBrush x:Key="ToolbarGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFFFFF" Offset="0"/>
        <GradientStop Color="#F0F0F0" Offset="0.5"/>
        <GradientStop Color="#E5E5E5" Offset="1"/>
    </LinearGradientBrush>

    <!-- Card Gradient -->
    <LinearGradientBrush x:Key="CardGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFFFFF" Offset="0"/>
        <GradientStop Color="#F8F8F8" Offset="1"/>
    </LinearGradientBrush>

    <!-- Button Hover Gradient -->
    <LinearGradientBrush x:Key="ButtonHoverGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#BEE6FD" Offset="0"/>
        <GradientStop Color="#A0D4F0" Offset="1"/>
    </LinearGradientBrush>

    <!-- Accent Gradient -->
    <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#7B68EE" Offset="0"/>
        <GradientStop Color="#9F8FFF" Offset="0.5"/>
        <GradientStop Color="#7B68EE" Offset="1"/>
    </LinearGradientBrush>

    <!-- ============================================== -->
    <!-- WINDOW & CONTROL BRUSHES (for theming)        -->
    <!-- ============================================== -->

    <!-- Window -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource BackgroundPrimaryColor}"/>
    <SolidColorBrush x:Key="WindowForegroundBrush" Color="{StaticResource TextPrimaryColor}"/>

    <!-- Menu -->
    <SolidColorBrush x:Key="MenuBackgroundBrush" Color="{StaticResource BackgroundCardColor}"/>
    <SolidColorBrush x:Key="MenuForegroundBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="MenuHoverBackgroundBrush" Color="{StaticResource BackgroundHoverColor}"/>
    <SolidColorBrush x:Key="MenuBorderBrush" Color="{StaticResource BorderColor}"/>

    <!-- Button -->
    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="{StaticResource BackgroundCardColor}"/>
    <SolidColorBrush x:Key="ButtonForegroundBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="ButtonHoverBackgroundBrush" Color="#A0BEE6FD"/>
    <SolidColorBrush x:Key="ButtonPressedBackgroundBrush" Color="{StaticResource PrimaryLightColor}"/>
    <SolidColorBrush x:Key="ButtonBorderBrush" Color="{StaticResource BorderColor}"/>

    <!-- TextBox / Editor -->
    <SolidColorBrush x:Key="EditorBackgroundBrush" Color="{StaticResource BackgroundCardColor}"/>
    <SolidColorBrush x:Key="EditorForegroundBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="EditorBorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="EditorSelectionBrush" Color="#403C7FB1"/>

    <!-- TabControl -->
    <SolidColorBrush x:Key="TabBackgroundBrush" Color="{StaticResource BackgroundSecondaryColor}"/>
    <SolidColorBrush x:Key="TabSelectedBackgroundBrush" Color="{StaticResource BackgroundCardColor}"/>
    <SolidColorBrush x:Key="TabForegroundBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TabSelectedForegroundBrush" Color="{StaticResource PrimaryColor}"/>

    <!-- ScrollBar -->
    <SolidColorBrush x:Key="ScrollBarBackgroundBrush" Color="{StaticResource BackgroundSecondaryColor}"/>
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#CCCCCC"/>
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="{StaticResource PrimaryColor}"/>

    <!-- Toggle/Radio Button -->
    <SolidColorBrush x:Key="ToggleBackgroundBrush" Color="{StaticResource BackgroundCardColor}"/>
    <SolidColorBrush x:Key="ToggleCheckedBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ToggleForegroundBrush" Color="#444444"/>
    <SolidColorBrush x:Key="ToggleCheckedForegroundBrush" Color="#000000"/>

    <!-- Greek Letter Panel (Original) -->
    <SolidColorBrush x:Key="GreekLetterHoverBrush" Color="Bisque"/>

    <!-- Syntax Highlighting Colors (Original) -->
    <SolidColorBrush x:Key="SyntaxKeywordBrush" Color="Blue"/>
    <SolidColorBrush x:Key="SyntaxFunctionBrush" Color="DarkCyan"/>
    <SolidColorBrush x:Key="SyntaxNumberBrush" Color="Goldenrod"/>
    <SolidColorBrush x:Key="SyntaxStringBrush" Color="ForestGreen"/>
    <SolidColorBrush x:Key="SyntaxCommentBrush" Color="DarkGray"/>
    <SolidColorBrush x:Key="SyntaxOperatorBrush" Color="Magenta"/>
    <SolidColorBrush x:Key="SyntaxErrorBrush" Color="Red"/>

    <!-- Output Panel -->
    <SolidColorBrush x:Key="OutputBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="OutputBorderBrush" Color="#DDDDDD"/>

    <!-- Splitter -->
    <SolidColorBrush x:Key="SplitterBackgroundBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="SplitterHoverBrush" Color="{StaticResource PrimaryColor}"/>

</ResourceDictionary>
