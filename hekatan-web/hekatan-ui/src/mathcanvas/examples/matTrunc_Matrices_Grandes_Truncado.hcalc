# Matrices y Vectores Grandes
> Truncado estilo Mathcad con indices y puntos suspensivos

## Vector Columna (100 elementos)
function[x] = vec(n)
  x = zeros(n, 1)
  for i = 1:n
    x[i, 1] = i
  end
end
A = vec(30)

## Matriz Diagonal (20x20)
function[x] = diagMat(n)
  x = zeros(n, n)
  for i = 1:n
    x[i, i] = i
  end
end
B = diagMat(20)

## Matriz Identidad 15x15
I_15 = identity(15)

## Matriz Pequeña (sin truncado)
C = [[1, 2, 3]; [4, 5, 6]; [7, 8, 9]]