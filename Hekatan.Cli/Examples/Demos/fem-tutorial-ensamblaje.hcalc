line 310 85 310 145 stroke:#2e7d32 width:1
line 255 115 375 115 stroke:#2e7d32 width:1
% Flecha
arrow 390 110 430 110 stroke:#333 width:2
text 410 100 "=" size:18 bold color:#333 anchor:middle
% Matriz global
text 540 55 "[K] GLOBAL 3×3" size:12 bold color:#1565c0 anchor:middle
text 490 75 "n1" size:10 color:#1565c0
text 540 75 "n2" size:10 color:#1565c0
text 590 75 "n3" size:10 color:#1565c0
rect 460 85 180 90 fill:#e3f2fd stroke:#1565c0 width:2
text 490 110 "+k₁" size:11 bold color:#c62828 anchor:middle
text 540 110 "-k₁" size:11 bold color:#c62828 anchor:middle
text 590 110 "0" size:11 color:#999 anchor:middle
text 490 135 "-k₁" size:11 bold color:#c62828 anchor:middle
text 540 135 "k₁+k₂" size:10 bold color:#9c27b0 anchor:middle
text 590 135 "-k₂" size:11 bold color:#2e7d32 anchor:middle
text 490 160 "0" size:11 color:#999 anchor:middle
text 540 160 "-k₂" size:11 bold color:#2e7d32 anchor:middle
text 590 160 "+k₂" size:11 bold color:#2e7d32 anchor:middle
line 510 85 510 175 stroke:#1565c0 width:1
line 560 85 560 175 stroke:#1565c0 width:1
line 460 120 640 120 stroke:#1565c0 width:1
line 460 145 640 145 stroke:#1565c0 width:1
% Nota
text 325 210 "Nodo 2 es COMPARTIDO → k₁+k₂ en diagonal" size:13 bold color:#9c27b0 anchor:middle
text 325 235 "Los ceros aparecen donde los nodos NO están conectados" size:11 color:#666 anchor:middle
text 325 255 "Esto es EXACTAMENTE lo que hace Awatif en getGlobalStiffnessMatrix.cpp" size:11 color:#333 anchor:middle
@{end svg}

@(h3 Ensamblaje con Maxima)

@{maxima}
k1: 100;
k2: 200;
/* Matriz global 3x3 ensamblada */
K_global: matrix(
  [k1,    -k1,     0  ],
  [-k1,  k1+k2,  -k2  ],
  [0,     -k2,    k2   ]
);
@{end maxima}

@(h2 4. Condiciones de Borde)

%Nodo 1 está fijo (u₁ = 0) → eliminamos fila 1 y columna 1:

@{maxima}
k1: 100;
k2: 200;
/* Eliminamos fila 1, columna 1 (nodo fijo) */
K_reduced: matrix(
  [k1+k2, -k2],
  [-k2,    k2]
);
/* Vector de fuerzas (solo nodos libres 2 y 3) */
F_vec: matrix([0],[50]);
@{end maxima}

@(h2 5. RESOLVER: [K]{u} = {F})

@{eqdef}
{u} = [K]⁻¹ × {F} | Desplazamientos = Inversa × Fuerzas
@{end eqdef}

@{maxima}
k1: 100;
k2: 200;
K_reduced: matrix([k1+k2, -k2],[-k2, k2]);
F_vec: matrix([0],[50]);
/* Inversa */
K_inv: invert(K_reduced);
/* Solución */
u: K_inv . F_vec;
@{end maxima}

%Con Calcpad verificamos:

u_2 = F/(k_1)
u_3 = F*(1/k_1 + 1/k_2)
'u₂ ='u_2' (desplazamiento nodo 2)
'u₃ ='u_3' (desplazamiento nodo 3)

