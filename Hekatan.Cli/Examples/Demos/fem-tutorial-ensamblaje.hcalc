text 240 85 "2" size:14 bold color:#1565c0 anchor:middle
% Resorte 2
line 248 100 310 95 stroke:#2e7d32 width:2
line 310 95 330 105 stroke:#2e7d32 width:2
line 330 105 350 95 stroke:#2e7d32 width:2
line 350 95 370 105 stroke:#2e7d32 width:2
line 370 105 390 95 stroke:#2e7d32 width:2
line 390 95 420 100 stroke:#2e7d32 width:2
text 335 75 "k₂" size:16 bold color:#2e7d32 anchor:middle
