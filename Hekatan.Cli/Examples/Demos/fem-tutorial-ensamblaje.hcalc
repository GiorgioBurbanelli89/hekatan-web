text 190 100 "+" size:18 bold color:#333 anchor:middle
% Matriz elem 2
text 310 55 "[K₂] local 2×2" size:12 bold color:#2e7d32 anchor:middle
text 280 75 "n2" size:10 color:#2e7d32
text 340 75 "n3" size:10 color:#2e7d32
rect 255 85 120 60 fill:#c8e6c9 stroke:#2e7d32 width:2
