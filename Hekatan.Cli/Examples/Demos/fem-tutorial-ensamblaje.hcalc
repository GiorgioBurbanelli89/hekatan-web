text 300 175 "3 nodos, 2 elementos, 3 DOF (u₁, u₂, u₃)" size:12 color:#333 anchor:middle
@{end svg}

%Datos:
k_1 = 100
k_2 = 200
F = 50

@(h2 2. Matriz Local de CADA Elemento)

%Cada resorte tiene la misma forma de matriz:

@{eqdef}
[k] = k × [+1, -1; -1, +1] | Matriz local 2×2 de un resorte
F = k × (u_j - u_i) | Fuerza = rigidez × desplazamiento relativo
@{end eqdef}

@{columns 2}

@(h3 Elemento 1: nodos 1→2)
@(color:red k₁ = 100)

@{maxima}
k1: 100;
K1_local: k1 * matrix([1,-1],[-1,1]);
@{end maxima}

@{column}

@(h3 Elemento 2: nodos 2→3)
@(color:green k₂ = 200)

@{maxima}
k2: 200;
K2_local: k2 * matrix([1,-1],[-1,1]);
@{end maxima}

@{end columns}

@(h2 3. ENSAMBLAJE - La Clave del FEM)

%El ensamblaje coloca cada [k] local en la posición correcta de [K] global.
%La regla es: el elemento conecta nodos i,j → aporta a las filas/columnas i,j.

@{svg 650 320}
background #fafafa
% Título
text 325 20 "PROCESO DE ENSAMBLAJE" size:16 bold color:#333 anchor:middle
% Matriz elem 1
text 80 55 "[K₁] local 2×2" size:12 bold color:#c62828 anchor:middle
text 55 75 "n1" size:10 color:#c62828
text 105 75 "n2" size:10 color:#c62828
rect 30 85 120 60 fill:#ffcdd2 stroke:#c62828 width:2
text 55 110 "+k₁" size:12 bold color:#c62828 anchor:middle
text 105 110 "-k₁" size:12 bold color:#c62828 anchor:middle
text 55 130 "-k₁" size:12 bold color:#c62828 anchor:middle
text 105 130 "+k₁" size:12 bold color:#c62828 anchor:middle
line 80 85 80 145 stroke:#c62828 width:1
line 30 115 150 115 stroke:#c62828 width:1
% Flecha
