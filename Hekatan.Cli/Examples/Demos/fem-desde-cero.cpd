line 290 100 305 85 stroke:#2e7d32 width:2
line 305 85 325 115 stroke:#2e7d32 width:2
line 325 115 345 85 stroke:#2e7d32 width:2
line 345 85 365 115 stroke:#2e7d32 width:2
