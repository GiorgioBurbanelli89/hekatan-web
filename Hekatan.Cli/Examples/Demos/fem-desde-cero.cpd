line 22 55 42 55 stroke:#555 width:1
line 22 75 42 75 stroke:#555 width:1
line 22 95 42 95 stroke:#555 width:1
line 22 115 42 115 stroke:#555 width:1
line 22 135 42 135 stroke:#555 width:1
% Nodo 1
circle 42 100 8 fill:#1565c0 stroke:#0d47a1 width:2
