"12. @{cpp} - C++ syntax highlighting
@{cpp}
#include <Eigen/Dense>
using namespace Eigen;

// Rigidez a flexion de placa Kirchhoff
double getFlexuralRigidity(double E, double t, double nu) {
    return E * pow(t, 3) / (12.0 * (1.0 - nu * nu));
}

// Matriz constitutiva Db
Matrix3d getDb(double E, double t, double nu) {
    double D = getFlexuralRigidity(E, t, nu);
    Matrix3d Db;
    Db << 1,  nu, 0,
          nu, 1,  0,
          0,  0,  (1-nu)/2;
    return D * Db;
}
@{end cpp}

"13. @{cpp} con int main - Compilacion y ejecucion
@{cpp}
#include <iostream>
#include <cmath>
int main() {
    double E = 35e6, t = 0.15, nu = 0.15;
    double D = E * pow(t, 3) / (12.0 * (1.0 - nu * nu));
    std::cout << "D = " << D << " kN·m" << std::endl;
    std::cout << "Esbeltez a/t = " << 6.0/t << std::endl;
    return 0;
}
@{end cpp}

"14. @{explain spanish} - Pseudocodigo en espanol
@{explain spanish}
double D = E * pow(t, 3) / (12.0 * (1.0 - nu * nu));
for (int i = 0; i < nNodes; i++) {
    if (supports[i] == 1) {
        K[i][i] = 1e20;
    }
}
double w_max = *max_element(w.begin(), w.end());
return w_max;
@{end explain}

"15. @{cpp-explain} - Tres columnas C++/Calcpad/Octave
@{cpp-explain}
// Rigidez a flexion
double D = (E*t*t*t)/(12.0*(1.0-nu*nu));
// Matriz constitutiva
Matrix3d Db;
Db << 1, nu, 0,
      nu, 1, 0,
      0, 0, (1-nu)/2;
// Escalar por D
Db = D * Db;
// Area del triangulo
double Ae = 0.5 * abs(x21*y31 - x31*y21);
@{end cpp-explain}

"16. @{maxima} - Algebra simbolica CAS
@{maxima}
/* Rigidez a flexion */
D: E*t^3/(12*(1-nu^2));
/* Sustituir valores */
D_val: subst([E=35e6, t=0.15, nu=0.15], D);
/* Derivada parcial */
dD_dt: diff(D, t);
/* Simplificar */
dD_simple: ratsimp(dD_dt);
@{end maxima}

