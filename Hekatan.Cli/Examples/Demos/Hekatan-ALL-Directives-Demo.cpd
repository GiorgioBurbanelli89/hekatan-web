"HEKATAN CALC - DEMO COMPLETO DE TODAS LAS DIRECTIVAS @{}
'Este archivo demuestra CADA directiva @{} soportada por Hekatan Calc.
'Incluye directivas built-in y lenguajes externos.

"1. Variables Hekatan nativas
a = 6
b = 4
c = a + b
t = 0.15
E = 35000000
ν = 0.15
D = E*t^3/(12*(1 - ν^2))
'Rigidez a flexion: D

"2. @{eq} - Ecuaciones formato display
@{eq}
w(x,y) = Σ A_mn · sin(mπx/a) · sin(nπy/b)
[K]{u} = {F}
{u} = [K]⁻¹{F}
σ = E · ε
@{end eq}

"3. @{eqdef} - Ecuaciones con definiciones
@{eqdef}
F = m × a | Segunda ley de Newton
σ = F / A | Esfuerzo = Fuerza / Area
ε = ΔL / L | Deformacion unitaria
D = Et³/12(1-ν²) | Rigidez a flexion de placa
[K]{u} = {F} | Sistema de rigidez FEM
@{end eqdef}

"4. @{function} - Definir funciones matematicas
@{function}
function y = cuadrado(x)
  y = x^2
end

function y = hipotenusa(a, b)
  y = sqrt(a^2 + b^2)
end

cubo(x) = x^3
doble(x) = 2*x
@{end function}

