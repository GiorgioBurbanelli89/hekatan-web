"27. @{c} - Compilacion y ejecucion C
@{c}
#include <stdio.h>
#include <math.h>
int main() {
    double E = 35e6, t = 0.15, nu = 0.15;
    double D = E * pow(t, 3) / (12.0 * (1.0 - nu * nu));
    printf("C: D = %.2f kN·m\n", D);
    printf("C: a/t = %.1f\n", 6.0/t);
    return 0;
}
@{end c}

"28. @{fortran} - Compilacion y ejecucion Fortran
@{fortran}
program plate_rigidity
  implicit none
  real(8) :: E, t, nu, D
  E = 35.0d6
  t = 0.15d0
  nu = 0.15d0
  D = E * t**3 / (12.0d0 * (1.0d0 - nu**2))
  print *, "Fortran: D =", D, "kN·m"
  print *, "Fortran: a/t =", 6.0d0/t
end program plate_rigidity
@{end fortran}

"29. @{rust} - Compilacion y ejecucion Rust
@{rust}
fn main() {
    let e: f64 = 35e6;
    let t: f64 = 0.15;
    let nu: f64 = 0.15;
    let d = e * t.powi(3) / (12.0 * (1.0 - nu * nu));
    println!("Rust: D = {:.2} kN·m", d);
    println!("Rust: a/t = {:.1}", 6.0 / t);
}
@{end rust}

